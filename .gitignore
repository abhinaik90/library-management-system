# Dependencies (always ignore)
node_modules/
*/node_modules/

# Environment variables (contains passwords & secrets)
.env
*.env
*.env.local

# Build outputs (not needed on GitHub)
dist/
build/
backend/dist/

# Log files
*.log
npm-debug.log*

# OS junk files
.DS_Store
Thumbs.db

# IDE settings (optional)
.vscode/
.idea/